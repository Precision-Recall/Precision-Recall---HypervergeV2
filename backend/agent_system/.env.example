# ─── OpenAI (Orchestrator LLM) ──────────────────────────────────────
# REQUIRED
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# ─── Bedrock Proxy (Inner Agent LLM) ────────────────────────────────
# REQUIRED — AWS Lambda function URL for the Bedrock proxy
BEDROCK_PROXY_URL=https://your-bedrock-url.lambda-url.us-east-1.on.aws/
BEDROCK_MODEL_ID=us.meta.llama4-scout-17b-instruct-v1:0
# Optional — max tokens for generation (default: 2048)
BEDROCK_MAX_GEN_LEN=2048

# ─── Embedding Service (BGE-M3) ─────────────────────────────────────
# REQUIRED — OpenAI-compatible embedding endpoint (e.g. LM Studio or custom server)
EMBEDDING_URL=http://your-embedding-server:1234/v1/embeddings
EMBEDDING_MODEL=text-embedding-bge-m3
# Optional — embedding dimension (default: 1024)
EMBEDDING_DIM=1024

# ─── Qdrant Vector Database ──────────────────────────────────────────
# REQUIRED
QDRANT_HOST=your-qdrant-host
QDRANT_PORT=6333
QDRANT_COLLECTION=your-collection-name

# ─── Retriever ───────────────────────────────────────────────────────
# Optional — number of candidates from HNSW search (default: 50)
TOP_K_HNSW=50

# ─── Tool Limits ─────────────────────────────────────────────────────
# Optional — max tool calls per agent turn (default: 5)
MAX_TOOL_CALLS=5

# ─── LangSmith Tracing (Optional) ───────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=your-project-name

# ─── Gemini / Vertex AI (Optional) ──────────────────────────────────
GEMINI_MODEL=gemini-1.5-pro
GEMINI_PROJECT=your-gcp-project-id
GEMINI_LOCATION=us-central1
# Path to a local .env file that contains GOOGLE_APPLICATION_CREDENTIALS_JSON
GEMINI_CREDENTIALS_FILE=/path/to/gcp-credentials.env
