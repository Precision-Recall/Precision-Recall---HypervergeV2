# ─── Bedrock Proxy (Caption/Vision LLM) ────────────────────────────
# REQUIRED — AWS Lambda function URL for the Bedrock proxy
BEDROCK_PROXY_URL=https://your-bedrock-url.lambda-url.us-east-1.on.aws/
BEDROCK_MODEL_ID=us.meta.llama4-scout-17b-instruct-v1:0

# ─── Embedding Service (BGE-M3) ─────────────────────────────────────
# REQUIRED — OpenAI-compatible embedding endpoint (e.g. LM Studio or custom server)
EMBEDDING_URL=http://your-embedding-server:1234/v1/embeddings
EMBEDDING_MODEL=text-embedding-bge-m3
# Optional — embedding dimension (default: 1024)
EMBEDDING_DIM=1024

# ─── Qdrant Vector Database ──────────────────────────────────────────
# REQUIRED
QDRANT_HOST=your-qdrant-host
QDRANT_PORT=6333
QDRANT_COLLECTION=your-collection-name

# ─── Processing Limits (Optional) ───────────────────────────────────
MAX_CHUNK_TOKENS=600
CHUNK_OVERLAP_TOKENS=100
MAX_PARALLEL_PDFS=2
MAX_PARALLEL_EMBEDDINGS=3
